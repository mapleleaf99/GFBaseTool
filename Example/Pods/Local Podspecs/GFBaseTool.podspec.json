{
  "name": "GFBaseTool",
  "version": "0.2.0",
  "summary": "GFBaseTool 是一个 iOS 基础工具库",
  "description": "GFBaseTool 提供常用 Extension、GCD 封装、Toast、网络请求、自定义控件等基础能力，\n适用于快速搭建 iOS 项目的基础设施层。",
  "homepage": "https://github.com/mapleleaf99/GFBaseTool",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "叫我锅先生": "mapleleaf99@126.com"
  },
  "source": {
    "git": "https://github.com/mapleleaf99/GFBaseTool.git",
    "tag": "0.2.0"
  },
  "platforms": {
    "ios": "12.0"
  },
  "swift_versions": "5.0",
  "default_subspecs": [
    "Core",
    "Network"
  ],
  "subspecs": [
    {
      "name": "Core",
      "source_files": [
        "GFBaseTool/Classes/Tool/**/*",
        "GFBaseTool/Classes/Toast/**/*"
      ],
      "dependencies": {
        "Toast-Swift": [
          "5.0.1"
        ]
      }
    },
    {
      "name": "Network",
      "source_files": "GFBaseTool/Classes/NetWork/**/*",
      "dependencies": {
        "GFBaseTool/Core": [],
        "Alamofire": [
          "~> 5.6.1"
        ]
      }
    }
  ],
  "swift_version": "5.0"
}
