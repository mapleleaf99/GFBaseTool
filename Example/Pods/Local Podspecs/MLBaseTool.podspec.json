{
  "name": "MLBaseTool",
  "version": "0.3.0",
  "summary": "MLBaseTool 是一个 iOS 基础工具库",
  "description": "MLBaseTool 提供常用 Extension、GCD 封装、Toast、网络请求、存储、权限、UI 组件等基础能力，\n适用于快速搭建 iOS 项目的基础设施层。",
  "homepage": "https://github.com/mapleleaf99/MLBaseTool",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "叫我锅先生": "mapleleaf99@126.com"
  },
  "source": {
    "git": "https://github.com/mapleleaf99/MLBaseTool.git",
    "tag": "0.3.0"
  },
  "platforms": {
    "ios": "12.0"
  },
  "swift_versions": "5.0",
  "default_subspecs": [
    "Core",
    "Storage",
    "Permission",
    "UI",
    "Network"
  ],
  "subspecs": [
    {
      "name": "Core",
      "source_files": [
        "MLBaseTool/Classes/Tool/**/*",
        "MLBaseTool/Classes/Toast/**/*"
      ],
      "dependencies": {
        "Toast-Swift": [
          "5.0.1"
        ]
      }
    },
    {
      "name": "Storage",
      "source_files": "MLBaseTool/Classes/Storage/**/*",
      "frameworks": "Security",
      "dependencies": {
        "MLBaseTool/Core": []
      }
    },
    {
      "name": "Permission",
      "source_files": "MLBaseTool/Classes/Permission/**/*",
      "frameworks": [
        "AVFoundation",
        "Photos",
        "CoreLocation",
        "UserNotifications"
      ],
      "dependencies": {
        "MLBaseTool/Core": []
      }
    },
    {
      "name": "UI",
      "source_files": "MLBaseTool/Classes/UI/**/*",
      "dependencies": {
        "MLBaseTool/Core": []
      }
    },
    {
      "name": "Network",
      "source_files": "MLBaseTool/Classes/NetWork/**/*",
      "dependencies": {
        "MLBaseTool/Core": [],
        "Alamofire": [
          "~> 5.6.1"
        ]
      }
    }
  ],
  "swift_version": "5.0"
}
